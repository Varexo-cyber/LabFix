# Neon PostgreSQL Database
DATABASE_URL=postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/labfix?sslmode=require

# Maintenance Mode - zet op 'true' om de website te locken
MAINTENANCE_MODE=false

# SMTP Email (Nodemailer) - voor orderbevestigingen
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jouw-email@gmail.com
SMTP_PASS=jouw-app-wachtwoord

# Mobile Sentrix API Configuration (OAuth 1.0a)
MOBILESENTRIX_API_URL=https://www.mobilesentrix.eu
MOBILESENTRIX_CONSUMER_KEY={{MOBILESENTRIX_CONSUMER_KEY}}
MOBILESENTRIX_CONSUMER_SECRET={{MOBILESENTRIX_CONSUMER_SECRET}}
MOBILESENTRIX_ACCESS_TOKEN={{MOBILESENTRIX_ACCESS_TOKEN}}
MOBILESENTRIX_ACCESS_TOKEN_SECRET={{MOBILESENTRIX_ACCESS_TOKEN_SECRET}}

# Cloudflare Worker Proxy (bypasses Cloudflare blocking)
MOBILESENTRIX_PROXY_URL=https://your-worker.your-name.workers.dev
